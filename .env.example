# -- DATABASE -----------------------------------------
POSTGRES_DB=hisab
POSTGRES_USER=hisab
POSTGRES_PASSWORD=your_secure_db_password

# -- SECURITY ------------------------------------------
# Generate a random string for this in production
SECRET_KEY=your_secret_key_here

# -- FIRST ADMIN (created on first boot) --------------
FIRST_ADMIN_EMAIL=admin@hisab.com
FIRST_ADMIN_PASSWORD=Admin@2024

# -- COMPANY DETAILS (printed on invoices/PDFs) --------
COMPANY_NAME="Your Company Name"
COMPANY_GSTIN="Your GSTIN"
COMPANY_ADDRESS="Your Full Address"
COMPANY_PHONE="Your Phone Number"

# -- DEPLOYMENT ----------------------------------------
ENVIRONMENT=development
VITE_API_URL=/api
